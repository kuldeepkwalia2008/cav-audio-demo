# Copy this file to .env.local for local development,
# and add the same variables in Vercel → Project → Settings → Environment Variables.

# Required for the AI chat assistant (api/chat.js)
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional but recommended — durable storage for lead enquiries (api/leads.js)
# Without these, leads are kept in memory only and may reset between deployments.
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
